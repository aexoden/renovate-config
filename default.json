{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    // Base the configuration on the official best-practices preset
    "config:best-practices",

    // Enable automerge
    "github>aexoden/renovate-config:automerge",

    // Group ESLint updates
    "github>aexoden/renovate-config:groupESLint",

    // Group updates for packages that can be in multiple repositories (e.g. node, uv)
    "github>aexoden/renovate-config:groupMultipleRepositories",

    // Set minimumReleaseAge for all datasources
    "github>aexoden/renovate-config:minimumReleaseAge",

    // Pin dependencies by default
    "github>aexoden/renovate-config:rangeStrategyPin",

    // Enable updates of Rust toolchain
    "github>Turbo87/renovate-config//rust/updateToolchain"
  ],

  // Ignore the best-practices minimumReleaseAgeNpm configuration as it conflicts with ours.
  "ignorePresets": ["security:minimumReleaseAgeNpm"]
}
